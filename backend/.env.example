# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opseazy
POSTGRES_USER=opseazy
POSTGRES_PASSWORD=changeme

# ─── Duffel (flight search & booking) ────────────────────────────────────────
DUFFEL_ACCESS_TOKEN=PLACEHOLDER
DUFFEL_API_URL=https://api.duffel.com

# ─── AviationStack (airline reference data & schedules — not booking) ─────────
# Sign up at https://aviationstack.com — free tier gives 100 req/month
# IMPORTANT: Free tier is HTTP only. Change to https:// on a paid plan.
AVIATIONSTACK_ACCESS_KEY=PLACEHOLDER
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_KEY=PLACEHOLDER

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
