# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opseazy
POSTGRES_USER=opseazy
POSTGRES_PASSWORD=changeme

# ─── Duffel API (https://duffel.com/docs) ─────────────────────
# Sign up → Settings → Access tokens → Create token (test mode)
# Test token starts with: duffel_test_
DUFFEL_ACCESS_TOKEN=PLACEHOLDER
DUFFEL_API_URL=https://api.duffel.com

# ─── Google Maps ──────────────────────────────────────────────
# Needs: Maps JavaScript API + Places API enabled
# Restrict to your domain via Google Cloud Console → APIs → Credentials
GOOGLE_MAPS_KEY=your_google_maps_api_key

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
